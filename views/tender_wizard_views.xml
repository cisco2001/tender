<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tender to Lead Conversion Wizard Form -->
    <record id="view_tender_to_lead_wizard_form" model="ir.ui.view">
        <field name="name">tender.to.lead.wizard.form</field>
        <field name="model">tender.to.lead.wizard</field>
        <field name="arch" type="xml">
            <form string="Convert Tender to Lead">
                <sheet>
                    <!-- Lead Basic Information -->
                    <div class="oe_title">
                        <h3>Lead Information</h3>
                    </div>
                    
                    <group>
                        <group string="Details (Pre-filled from Tender)">
                            <field name="tender_id" invisible="1"/>
                            <field name="name" required="1" placeholder="e.g. IT Infrastructure Tender"/>
                            <field name="partner_name" placeholder="Company/Institution name"/>
                            <field name="expected_revenue" placeholder="0.00"/>
                            <field name="currency_id" options="{'no_create': True}"/>
                            <field name="date_deadline" help="Expected closing date for this opportunity"/>
                        </group>
                        <group string="Contact Information">
                            <field name="email_from" widget="email" placeholder="xyz@example.com"/>
                            <field name="phone" widget="phone" placeholder="+25x.."/>
                        </group>
                    </group>
                    
                    <!-- Sales Assignment Section -->
                    <div class="oe_title" style="margin-top: 20px;">
                        <h3>Sales Assignment</h3>
                    </div>
                    
                    <group>
                        <group string="Team Assignment" class="oe_highlight">
                            <field name="user_id" required="1" options="{'no_create': True}" 
                                   help="Who will be responsible for this lead?"/>
                            <field name="team_id" options="{'no_create': True}" 
                                   help="Which sales team should handle this lead?"/>
                            <field name="account_manager" options="{'no_create': True}" 
                                   help="Who will manage the customer relationship and account?"/>
                            <field name="source_id" options="{'no_create': True}" 
                                   help="How did you acquire this lead? (e.g. Tender Portal or Direct Contact)"/>
                        </group>
                        <group string="Business and Pre-sales Assignment">
                            <field name="business_unit" options="{'no_create': True}" 
                                   help="Which business unit will handle this lead?"/>
                            <field name="pre_sale_id" options="{'no_create': True}" 
                                   help="Who will handle the technical pre-sales activities?"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Tender Description" attrs="{'invisible': [('description', '=', False)]}">
                            <field name="description" widget="html" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                
                <footer>
                    <button name="action_convert_to_lead" string="Create Lead" type="object" 
                            class="btn-primary oe_highlight" 
                            style="min-width: 120px;"
                            help="Convert this tender to a CRM lead with tender status set to Yes"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_tender_to_lead_wizard" model="ir.actions.act_window">
        <field name="name">Convert to Lead</field>
        <field name="res_model">tender.to.lead.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'active_id': active_id, 'active_model': 'tender.tender'}</field>
    </record>
</odoo>